{
  "name": "wayfinderkiosk",
  "version": "1.0.0",
  "description": "Airport Wayfinder Kiosk - Navigation and wayfinding application",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:interactions": "playwright test tests/ui-interactions.spec.ts",
    "test:memory": "playwright test tests/memory-monitoring.spec.ts",
    "test:accessibility": "playwright test tests/accessibility.spec.ts",
    "test:extended": "playwright test tests/memory-leak-extended.spec.ts --headed --workers=1",
    "test:report": "playwright show-report"
  },
  "keywords": [
    "wayfinder",
    "kiosk",
    "airport",
    "navigation"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "i18next": "^25.7.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-i18next": "^16.4.0",
    "react-virtualized-auto-sizer": "^1.0.26",
    "react-window": "^2.2.3",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@tailwindcss/vite": "^4.1.17",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^9.0.3",
    "workbox-window": "^7.4.0"
  }
}
